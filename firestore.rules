rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitives & Global Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- PHASE 4: Entity Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['goal', 'level', 'time', 'onboarded', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.goal is string && data.goal.size() <= 100 &&
             data.level is string && data.level.size() <= 50 &&
             data.time is string && data.time.size() <= 20 &&
             data.onboarded is bool &&
             data.createdAt is string; // ISO String as per current code
    }

    function isValidWorkout(data) {
      return data.keys().hasAll(['workoutName', 'createdAt']) &&
             data.workoutName is string && data.workoutName.size() <= 200 &&
             data.duration is number &&
             data.difficulty is string &&
             data.warmup is list &&
             data.mainExercises is list &&
             data.coolDown is list &&
             data.createdAt is string;
    }

    // --- COLLECTIONS ---

    // /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming());
      
      allow update: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['goal', 'level', 'time', 'onboarded']);
    }

    // /users/{userId}/history/{workoutId}
    match /users/{userId}/history/{workoutId} {
      allow list: if isOwner(userId) && isValidId(userId);
      allow get: if isOwner(userId) && isValidId(userId) && isValidId(workoutId);
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidId(workoutId) && 
                      isValidWorkout(incoming());
      
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
